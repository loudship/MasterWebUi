# Required operator-supplied secrets. Do not commit real values.
POSTGRES_USER=airgap_operator
POSTGRES_PASSWORD=replace_with_a_long_random_password
PIPELINES_API_KEY=replace_with_a_long_random_pipeline_key
WEBUI_SECRET_KEY=replace_with_a_long_random_webui_key
AES_SECRET_KEY=replace_with_a_long_random_vault_key

# Canonical gateway policy. Host LM Studio must listen on 127.0.0.1:1234.
MODEL_ALLOWLIST=replace_with_an_exact_lm_studio_model_id
UPSTREAM_TIMEOUT_S=180

# Optional internal-only tool profile.
ALLOWED_TARGET_HOSTS=crawl4ai,searxng,browserless

# Maintenance-only atomic Qdrant cutover.
QDRANT_ALIAS=narrative_active
QDRANT_TARGET_COLLECTION=
QDRANT_SNAPSHOT_CURRENT=true
