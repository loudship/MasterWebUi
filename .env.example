# Required operator-supplied secrets. Do not commit real values.
POSTGRES_USER=airgap_operator
POSTGRES_PASSWORD=replace_with_a_long_random_password
PIPELINES_API_KEY=replace_with_a_long_random_pipeline_key
WEBUI_SECRET_KEY=replace_with_a_long_random_webui_key
AES_SECRET_KEY=replace_with_a_long_random_vault_key
CALENDAR_DB_PASSWORD=replace_with_a_long_random_calendar_password
CALENDAR_MCP_JWT_SECRET_KEY=replace_with_a_long_random_calendar_jwt_secret
# Read-only telemetry role password. Rotating it on an EXISTING database
# requires a manual `ALTER ROLE telemetry_ro PASSWORD ...` — init scripts only
# run on first initialization of the postgres volume.
TELEMETRY_RO_PASSWORD=replace_with_a_long_random_telemetry_password
# Optional, required only for live Google Calendar data. Keep this file outside the repository.
GOOGLE_APPLICATION_CREDENTIALS_HOST_PATH=C:/secure/google-calendar-adc.json

# Canonical gateway policy. Host LM Studio must listen on 127.0.0.1:4321
# (UPSTREAM_BASE_URL in docker-compose.yml targets host.docker.internal:4321).
MODEL_ALLOWLIST=replace_with_an_exact_lm_studio_model_id
UPSTREAM_TIMEOUT_S=180

# Admin API key issued by Open WebUI (Settings → Account → API Keys).
# Used by workspace-catalog service to read workspace items via the public API.
OPEN_WEBUI_API_KEY=replace_with_open_webui_admin_api_key

# Optional internal-only tool profile.
ALLOWED_TARGET_HOSTS=crawl4ai,searxng,browserless

# Maintenance-only atomic Qdrant cutover.
QDRANT_ALIAS=narrative_active
QDRANT_TARGET_COLLECTION=
QDRANT_SNAPSHOT_CURRENT=true
