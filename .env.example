# Open WebUI Environment Variables (Example Template)
# Copy this file to .env and configure the values for your local setup.

# Base URL for the LLM inference server (e.g. LM Studio, Ollama, etc.)
OPENAI_API_BASE_URL=http://host.docker.internal:4321/v1

# RAG & Web Search Settings
ENABLE_WEB_SEARCH=True
WEB_SEARCH_ENGINE=searxng
SEARXNG_QUERY_URL=http://searxng:8080/search?q=<query>
WEB_SEARCH_TRUST_ENV=True
WEB_SEARCH_RESULT_COUNT=2
WEB_LOADER_CONCURRENT_REQUESTS=2
WEB_SEARCH_CONCURRENT_REQUESTS=10
RAG_SYSTEM_CONTEXT=True

# Open WebUI Security Keys
# Generate a secure random string (e.g. openssl rand -hex 32)
WEBUI_SECRET_KEY=generate_your_own_secure_key_here
WEBUI_AUTH_TRUSTED_EMAIL_HEADERS=

# Open WebUI Pipelines Settings
PIPELINES_API_KEY=0p3n-w3bu!

# Advanced Scraper & Content Parsers (Crawl4ai, Docling)
WEB_LOADER_ENGINE=external
EXTERNAL_WEB_LOADER_URL=http://crawl4ai-proxy:8000/crawl
EXTERNAL_WEB_LOADER_API_KEY=local_bypass
CONTENT_EXTRACTION_ENGINE=docling
DOCLING_ENGINE_URL=http://docling-serve:5001
ENABLE_OPENAI_IMAGE_URL=True

# Code Evaluation Valve overrides
CODE_EVAL_VALVE_OVERRIDE_MAX_RUNTIME_SECONDS=30
CODE_EVAL_VALVE_OVERRIDE_REQUIRE_RESOURCE_LIMITING=True
CODE_EVAL_VALVE_OVERRIDE_AUTO_INSTALL=True

# Langfuse LLM Observability
LANGFUSE_HOST=http://langfuse-server:3000
LANGFUSE_PUBLIC_KEY=pk-lf-CHANGEME
LANGFUSE_SECRET_KEY=sk-lf-CHANGEME

# Model configuration options
USE_MODEL_NAME=true

# Deep Web MCP cryptographic secret key
# Generate a secure random string (e.g. openssl rand -hex 32)
AES_SECRET_KEY=generate_your_own_aes_secret_key_here
