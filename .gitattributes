# Git attributes for consistent cross-platform development (Windows + Linux containers + Open WebUI sources)
# See: https://git-scm.com/docs/gitattributes

# Default: let Git handle line endings intelligently based on platform (core.autocrlf)
* text=auto

# Force LF line endings for cross-platform text sources (Python, shell, Docker, web, configs, docs)
# This eliminates CRLF warnings on Windows checkouts and keeps Docker/Linux happy.
*.py text eol=lf
*.sh text eol=lf
Dockerfile* text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.ts text eol=lf
*.svelte text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary files (explicit)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar* binary
*.whl binary
*.gguf binary
*.safetensors binary
*.db binary
*.sqlite* binary

# Generated / large data (diffs not useful)
data/** binary
backups/** binary
backup/** binary
*.log binary
*.pyc binary
__pycache__/** binary
wheelhouse/** binary
open-webui-0.9.6/** binary
tmp_retrieval/** binary
