# Git Ignore Rules for MasterWebUi Workspace

# Environment variables containing sensitive keys and secrets
.env

# Docker volumes and local data directories (ignored except SearXNG settings template)
data/*
!data/searxng/
data/searxng/*
!data/searxng/settings.yml

# External skills repository (separately managed git clone)
langfuse-skills/

# Output and temporary log files
out.txt
db_output.txt
*.log
*.log.*
*.out
*.err
*.tmp
logs/
.pytest_cache/
.agents/

# Local databases and transient SQLite sidecars
*.db
*.sqlite*
*-wal
*-shm
*-journal

# Local model weights and caches
*.gguf
*.safetensors
*.ckpt
*.pt
*.pth
*.onnx
models/
weights/
.cache/
model-cache/
model_cache/

# Python files
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
env/

# Operating System files
.DS_Store
Thumbs.db
Desktop.ini

# Local backup artifacts and generated archives
backup/
backups/
backup_staging_*/
*.sha256
*.parity
*.pars
*.tar.gz
*.tar.zst

# Large local source snapshots and scratch trees
open-webui-0.9.6/
tmp_retrieval/

# Local Docker volume directories
docker-volumes/
.docker-volumes/
local-volumes/
