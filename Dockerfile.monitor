# =============================================================================
# Dockerfile.monitor
# Ghost Command Offline Ecosystem — CPU Monitor Daemon
# =============================================================================
#
# Builds a Python 3.11-slim image that runs monitor_daemon.py as a FastAPI
# service on port 9000.
#
# Design constraints
# ------------------
#   - No CUDA / GPU runtime installed — device="cpu" is enforced in code.
#   - sentence-transformers downloads all-MiniLM-L6-v2 to the local model
#     cache on first boot (or from a pre-baked volume).
#   - CPU thread count is tunable via CPU_THREADS env var (default 4).
#
# Build:
#   docker build -f Dockerfile.monitor -t monitor-daemon:latest .
# =============================================================================

FROM monitor-daemon@sha256:f979055cc5dedfee9d523a380a08c46e85201099b130fd394fe8bbe2f3cab5ed

WORKDIR /app
COPY monitor_daemon.py ./monitor_daemon.py
COPY monitor_dashboard.html ./monitor_dashboard.html
COPY monitor_app ./monitor_app
COPY monitor_ui ./monitor_ui

# ---------------------------------------------------------------------------
# Runtime environment defaults (all overridable via docker-compose)
# ---------------------------------------------------------------------------
ENV QDRANT_URL="http://qdrant:6333" \
    QDRANT_COLLECTION="monitor_active" \
    MCP_URL="http://deep-web-mcp:8000" \
    ORCHESTRATOR_URL="http://langgraph-orchestrator:8100" \
    SEARXNG_URL="http://searxng:8080" \
    CRAWL4AI_PROXY_URL="http://crawl4ai-proxy:8000" \
    OPEN_WEBUI_URL="http://open-webui:8080" \
    BROWSERLESS_URL="http://browserless:3000" \
    OPEN_WEBUI_PROMPT_MODEL_ID="qwen35" \
    MONITOR_DB_PATH="/app/data/control-center.db" \
    DIAGNOSTIC_RETENTION_DAYS="30" \
    DIAGNOSTIC_MAX_RUNS="500" \
    PROBE_CACHE_TTL_S="15" \
    WEB_TOOLS_TIMEOUT_S="90" \
    DRIFT_THRESHOLD="0.15" \
    EMBED_MODEL_NAME="sentence-transformers/all-MiniLM-L6-v2" \
    CPU_THREADS="4" \
    MCP_TIMEOUT_S="90" \
    QDRANT_TIMEOUT_S="10" \
    ALERT_TIMEOUT_S="30" \
    PYTHONUNBUFFERED="1" \
    PYTHONDONTWRITEBYTECODE="1"

USER root
RUN mkdir -p /app/data && chown -R monitor:monitor /app/data

USER monitor

# ---------------------------------------------------------------------------
# Expose and launch
# ---------------------------------------------------------------------------
EXPOSE 9000
ENTRYPOINT ["python", "-m", "uvicorn", "monitor_daemon:app", \
            "--host", "0.0.0.0", "--port", "9000", "--workers", "1"]
